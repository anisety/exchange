{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Exchange API",
  "description": "REST and WebSocket reference for the Quant@Illinois trading competition—written for teams building bots and trading clients.",
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#1F7A5A"
  },
  "api": {
    "mdx": {
      "server": "https://exchange.jamesxu.dev",
      "auth": {
        "method": "key",
        "name": "x-api-key"
      }
    },
    "playground": {
      "display": "simple"
    },
    "examples": {
      "languages": [
        "curl",
        "javascript"
      ],
      "defaults": "required"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Welcome",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "reference/competition-guide",
              "reference/authentication"
            ]
          },
          {
            "group": "Trading Rules",
            "pages": [
              "reference/market-lifecycle",
              "reference/rate-limits",
              "reference/recovery-and-resync",
              "reference/error-codes"
            ]
          }
        ]
      },
      {
        "tab": "REST API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "reference/rest-api"
            ]
          },
          {
            "group": "Public",
            "pages": [
              "rest/health",
              "rest/markets"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "rest/user",
              "rest/portfolio",
              "rest/balance",
              "rest/positions",
              "rest/open-orders",
              "rest/fills"
            ]
          },
          {
            "group": "Trading",
            "pages": [
              "rest/submit-order",
              "rest/amend-order",
              "rest/cancel-order"
            ]
          }
        ]
      },
      {
        "tab": "WebSocket API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "reference/websocket-api",
              "websocket/server-messages"
            ]
          },
          {
            "group": "Connection",
            "pages": [
              "websocket/authenticate",
              "websocket/subscribe-data-stream",
              "websocket/unsubscribe-data-stream"
            ]
          },
          {
            "group": "Trading",
            "pages": [
              "websocket/submit-order",
              "websocket/amend-order",
              "websocket/cancel-order"
            ]
          }
        ]
      }
    ]
  }
}
