BIND_ADDR=0.0.0.0:8080
DATABASE_URL=postgres://exchange:exchange@localhost:5432/exchange
STORAGE_BACKEND=in_memory
WS_BROADCAST_BUFFER=1024
WS_MARKET_BROADCAST_WORKERS=4
MARKET_DATA_SERVICE_SOCKET=/tmp/exchange-marketdata.sock
MARKET_DATA_SERVICE_RETRY_BACKOFF_MS=250
PER_USER_RATE_LIMIT_BURST_CAPACITY=500
PER_USER_RATE_LIMIT_BURST_WINDOW_SECONDS=10
ADMIN_API_TOKEN=Quant2024!
POSTGRES_WRITE_BATCH_SIZE=128
POSTGRES_WRITE_FLUSH_INTERVAL_MS=25
POSTGRES_WRITE_QUEUE_CAPACITY=4096
POSTGRES_WRITE_RETRY_BACKOFF_MS=250
RUST_LOG=exchange=info,tower_http=info
